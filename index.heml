<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>練習試合チェックリスト</title>
<style>
body {
    font-family: sans-serif;
    margin: 0;
    display: flex;
}

.side-img {
    width: 20%;
    background-size: cover;
    background-position: center;
}

.container {
    width: 60%;
    padding: 20px;
}

h1 {
    text-align: center;
}

.group {
    border: 2px solid #ccc;
    border-radius: 10px;
    padding: 10px;
    margin-bottom: 15px;
}

.group-title {
    font-weight: bold;
    margin-bottom: 8px;
}

.indent {
    margin-left: 1em;
}

label {
    display: block;
}

/* レスポンシブ */
@media (max-width: 800px) {
    .side-img { display: none; }
    .container { width: 100%; }
}
</style>
</head>

<body>

<!-- 左画像 -->
<div class="side-img" style="background-image: url('your-image.png');"></div>

<div class="container">
<h1>練習試合チェックリスト</h1>

<div id="checklist"></div>

</div>

<!-- 右画像 -->
<div class="side-img" style="background-image: url('your-image.png');"></div>

<script>
const data = [
{
title: "ユニフォーム",
items: [
"ユニフォーム＿着（＿番～＿番）",
"ビブス＿着（＿番～＿番）"
]
},
{
title: "ボール",
items: [
"ボール＿個",
"ボールかご",
"ボールバック"
]
},
{
title: "ベンチ道具",
items: [
"スコアシート",
"筆記用具",
"作戦盤",
"試合球（空気チェックする）",
"救急バック",
"うちわ",
"足マット",
"ベンチタオル",
"ベンチ毛布",
"クーラーボックス",
{ text:"氷嚢（各自）", indent:true },
{ text:"コーチドリンク", indent:true },
{ text:"審判ドリンク", indent:true },
{ text:"予備のドリンク", indent:true },
"選手ドリンク用かご２つ",
"消毒（タオルも一緒に）",
"マスク"
]
},
{
title: "その他",
items: [
"ブルーシート",
"団旗（大会時必須）"
]
},
{
title: "練習試合関連",
items: [
"お茶菓子",
"来客用ドリンク（珈琲類）",
"タイムテーブル（５枚　TO席・舞台・応援席用・その他）",
"対戦相手ネームプレート（２枚ずつ　ラミ加工）",
"対戦相手控室準備",
"対戦相手控室用ネーム"
]
}
];

const container = document.getElementById("checklist");

// 保存
function save() {
    const checks = document.querySelectorAll("input[type=checkbox]");
    const state = [];
    checks.forEach(c => state.push(c.checked));
    localStorage.setItem("checklist", JSON.stringify(state));
}

// 読み込み
function load() {
    const state = JSON.parse(localStorage.getItem("checklist") || "[]");
    const checks = document.querySelectorAll("input[type=checkbox]");
    checks.forEach((c,i) => {
        if(state[i]) c.checked = true;
    });
}

let index = 0;

data.forEach(group => {
    const div = document.createElement("div");
    div.className = "group";

    const title = document.createElement("div");
    title.className = "group-title";
    title.textContent = group.title;
    div.appendChild(title);

    group.items.forEach(item => {
        let text = item;
        let indent = false;

        if(typeof item === "object") {
            text = item.text;
            indent = item.indent;
        }

        const label = document.createElement("label");
        if(indent) label.classList.add("indent");

        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.dataset.index = index++;

        checkbox.addEventListener("change", save);

        label.appendChild(checkbox);
        label.appendChild(document.createTextNode(" " + text + "、"));

        div.appendChild(label);
    });

    container.appendChild(div);
});

load();
</script>

</body>
</html>